---
import Button from "./components/Button.astro";

interface Props {
	variant?: 'compact' | 'full';
}

const { variant = 'full' } = Astro.props;
---

{variant === 'compact' ? (
	<div class="parcours-cta-compact px-6 py-4 bg-yellow-soft dark:bg-purple-darker border-y-3 border-black dark:border-purple-bright">
		<div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
			<p class="text-lg font-bold poppins text-black dark:text-white">
				42 parcours interactifs t'attendent — avec checklists, XP et badges.
			</p>
			<Button href="/parcours" color="var(--brand-yellow)">
				Voir les Parcours
			</Button>
		</div>
	</div>
) : (
	<section class="px-6 py-16 bg-purple-light dark:bg-purple-darker">
		<div class="max-w-4xl mx-auto text-center">
			<h2 class="text-3xl md:text-5xl font-bold mb-6 poppins text-black dark:text-white">
				Arrete de chercher "le bon business" dans le vide
			</h2>
			<p class="text-xl md:text-2xl mb-8 text-black dark:text-white">
				Entre par le quiz si tu hesites encore. Entre par les parcours si tu veux deja un plan d'action structure.
			</p>
			<div class="flex flex-col md:flex-row gap-4 justify-center items-center">
				<Button href="/quiz" color="var(--brand-yellow)">
					Faire le quiz
				</Button>
				<Button href="/parcours" color="var(--brand-orange)">
					Voir les 42 parcours
				</Button>
			</div>
		</div>
	</section>
)}
