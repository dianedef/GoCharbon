---
import { getCollection } from "astro:content";
import { filterBuildVisiblePosts } from "../utils/build-posts";
import { applyContentScope } from "../utils/content-section";

const allPosts = filterBuildVisiblePosts(await getCollection("posts"))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const latestApps = applyContentScope(allPosts, "apps").slice(0, 3);
const latestBlogPosts = applyContentScope(allPosts, "blog").slice(0, 3);
const latestTutos = applyContentScope(allPosts, "tutos").slice(0, 3);

function getPreviewImageSrc(image: unknown): string {
  if (typeof image === "string") return image;
  if (image && typeof image === "object" && "src" in image && typeof image.src === "string") {
    return image.src;
  }
  return "/placeholder.jpg";
}

const shortcuts = [
  {
    kicker: "Apps francophones",
    title: "Trouve une stack plus vite",
    description: "Va droit aux outils utiles au lieu de comparer au hasard des logiciels qui ne collent ni à ton budget ni à ton niveau.",
    href: "/apps",
    cta: "Voir toutes les apps",
    itemCta: "Voir l'app",
    items: latestApps,
  },
  {
    kicker: "Flux RSS",
    title: "Suivre sans laisser ton email",
    description: "Tu veux la veille et les nouveaux contenus sans formulaire ni séquence email ? Le feed est là pour ça.",
    href: "/feed.xml",
    cta: "Ouvrir le feed RSS",
    itemCta: "Voir l'article",
    items: latestBlogPosts,
  },
  {
    kicker: "Tutos",
    title: "Débloque un problème précis",
    description: "Prospection, acquisition, SEO, automatisation, outils : pioche un guide concret sur le point qui te ralentit maintenant.",
    href: "/tutos",
    cta: "Voir tous les tutos",
    itemCta: "Voir le tuto",
    items: latestTutos,
  },
];
---

<section class="shortcut-section bg-purple-pale dark:bg-purple-darker">
  <div class="px-6 py-16 max-w-6xl mx-auto">
    <div class="shortcut-header">
      <p class="shortcut-kicker">RACCOURCIS GOCHARBON</p>
      <h2 class="shortcut-title poppins">Des points d'entrée utiles, même si tu ne veux rien laisser</h2>
      <p class="shortcut-copy">
        Chaque bloc te donne un échantillon réel du contenu disponible, puis un accès direct à la section complète.
      </p>
    </div>
    <div class="shortcut-grid">
      {shortcuts.map((shortcut) => (
        <article class="shortcut-card">
          <div class="shortcut-card-head">
            <p class="shortcut-card-kicker">{shortcut.kicker}</p>
            <h3>{shortcut.title}</h3>
            <p class="shortcut-card-copy">{shortcut.description}</p>
          </div>

          <div class="shortcut-preview-list">
            {shortcut.items.map((item) => (
              <a href={`/${item.id}`} class="shortcut-preview-item no-link-style">
                <div class="shortcut-preview-main">
                  <div class="shortcut-preview-content">
                    <strong>{item.data.title}</strong>
                    <span>{item.data.description}</span>
                  </div>
                  <div class="shortcut-preview-thumb">
                    <img
                      src={getPreviewImageSrc(item.data.imgUrl)}
                      alt={item.data.title}
                      width="72"
                      height="72"
                      loading="lazy"
                      class="shortcut-preview-image"
                    />
                  </div>
                </div>
                <div class="shortcut-preview-action" aria-hidden="true">
                  <span class="shortcut-preview-action-label">{shortcut.itemCta}</span>
                  <span class="shortcut-preview-action-icon">→</span>
                </div>
              </a>
            ))}
          </div>

          <div class="shortcut-card-footer">
            <a href={shortcut.href} class="shortcut-cta no-link-style">
              {shortcut.cta} →
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .shortcut-header,
  .shortcut-card,
  .shortcut-card-head,
  .shortcut-preview-list {
    display: grid;
    gap: 0.75rem;
  }

  .shortcut-header {
    margin-bottom: 1.5rem;
  }

  .shortcut-kicker,
  .shortcut-card-kicker {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .shortcut-title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.98;
  }

  .shortcut-copy {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.55;
    max-width: 62rem;
  }

  .shortcut-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    align-items: stretch;
  }

  .shortcut-card {
    padding: 1.2rem;
    border: 3px solid var(--brand-black);
    border-radius: 0.45rem;
    background: rgb(245 245 242 / 0.92);
    box-shadow: 6px 6px 0 var(--brand-black);
    grid-template-rows: auto 1fr auto;
  }

  .shortcut-card h3,
  .shortcut-preview-item strong {
    margin: 0;
    font-family: "Poppins", sans-serif;
  }

  .shortcut-card h3 {
    font-size: 1.4rem;
  }

  .shortcut-card-copy {
    margin: 0;
    line-height: 1.55;
  }

  .shortcut-preview-item {
    display: grid;
    gap: 0.6rem;
    padding: 0.85rem 0.9rem;
    border: 2px solid var(--brand-black);
    border-radius: 0.35rem;
    background: rgb(255 255 255 / 0.52);
    transition: transform 0.15s ease, background-color 0.15s ease;
  }

  .shortcut-preview-main {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 4.5rem;
    gap: 0.75rem;
    align-items: start;
  }

  .shortcut-preview-content {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .shortcut-preview-thumb {
    width: 4.5rem;
    height: 4.5rem;
    border: 2px solid var(--brand-black);
    border-radius: 0.35rem;
    overflow: hidden;
    background: rgb(0 0 0 / 0.06);
  }

  .shortcut-preview-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .shortcut-preview-item:hover {
    transform: translate(1px, 1px);
    background: rgb(246 199 0 / 0.16);
  }

  .shortcut-preview-item strong {
    font-size: 0.98rem;
    line-height: 1.25;
  }

  .shortcut-preview-item span {
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .shortcut-preview-action {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.45rem;
  }

  .shortcut-preview-action-label,
  .shortcut-preview-action-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    border: 2px solid var(--brand-black);
    background: var(--brand-cream);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .shortcut-preview-action-label {
    padding: 0.2rem 0.65rem;
  }

  .shortcut-preview-action-icon {
    width: 2rem;
    min-width: 2rem;
  }

  .shortcut-card-footer {
    margin-top: 0.25rem;
  }

  .shortcut-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3rem;
    padding: 0.85rem 1rem;
    border: 3px solid var(--brand-black);
    background: var(--brand-yellow);
    box-shadow: 4px 4px 0 var(--brand-black);
    font-family: "Sanchez", serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--brand-black);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
  }

  .shortcut-cta:hover {
    transform: translate(1px, 1px);
    box-shadow: 3px 3px 0 var(--brand-black);
    background: var(--brand-orange);
    color: white;
  }

  :global(.dark) .shortcut-card {
    border-color: var(--brand-cream);
    background: rgb(11 11 11 / 0.9);
    box-shadow: 6px 6px 0 var(--brand-cream);
  }

  :global(.dark) .shortcut-preview-item {
    border-color: var(--brand-cream);
    background: rgb(255 255 255 / 0.04);
  }

  :global(.dark) .shortcut-preview-thumb,
  :global(.dark) .shortcut-preview-action-label,
  :global(.dark) .shortcut-preview-action-icon {
    border-color: var(--brand-cream);
    background: rgb(255 255 255 / 0.04);
  }

  :global(.dark) .shortcut-preview-item:hover {
    background: rgb(246 199 0 / 0.12);
  }

  :global(.dark) .shortcut-cta {
    border-color: var(--brand-cream);
    background: var(--brand-ink);
    box-shadow: 4px 4px 0 var(--brand-cream);
    color: var(--brand-cream);
  }

  :global(.dark) .shortcut-cta:hover {
    box-shadow: 3px 3px 0 var(--brand-cream);
    background: var(--brand-yellow);
    color: var(--brand-black);
  }

  @media (max-width: 1023px) {
    .shortcut-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .shortcut-preview-action-label {
      display: none;
    }

    .shortcut-preview-main {
      grid-template-columns: minmax(0, 1fr) 3.75rem;
    }

    .shortcut-preview-thumb {
      width: 3.75rem;
      height: 3.75rem;
    }
  }
</style>
