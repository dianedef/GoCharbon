---
import type { ButtonProps } from "../../utils/types/ui";
import colors from "../config/colors.json";

type Props = ButtonProps & { variant?: 'default' | 'hero' };

const {
	href,
	target = "_self",
	color = colors.light[Math.floor(Math.random() * colors.light.length)],
	darkColor = colors.dark[Math.floor(Math.random() * colors.dark.length)],
	variant = 'default'
} = Astro.props;

const shadowColor = variant === 'hero' ? 'var(--brand-yellow)' : 'var(--brand-yellow)';
---

<style define:vars={{ color, shadowColor }}>
	a.brutal-btn {
		filter: drop-shadow(5px 5px 0 rgb(0 0 0 / 1));
		background-color: var(--brand-cream);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1rem 2rem;
		border: 3px solid var(--brand-black);
		transition: all;
		transition-duration: 0.5s;
		animation: ease-in-out;
		font-family: "Sanchez", serif;
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--brand-black);
		cursor: pointer;
		position: relative;
		z-index: 3;
		pointer-events: auto;
	}
	a.brutal-btn:hover {
		filter: drop-shadow(3px 3px 0 rgb(0 0 0 / 1));
		background-color: var(--color);
	}

	:global(.dark) a.brutal-btn {
		filter: drop-shadow(5px 5px 0 var(--shadowColor));
		background-color: var(--brand-ink);
		border: 3px solid var(--shadowColor);
		color: var(--shadowColor);
	}

	:global(.dark) a.brutal-btn:hover {
		filter: drop-shadow(3px 3px 0 var(--shadowColor));
		background-color: var(--color);
	}
</style>

<a href={href} target={target} class="brutal-btn" data-astro-reload>
	<slot />
</a>
