---
import ToolQualificationCard from "./ToolQualificationCard.astro";
import type { ToolQualification } from "../../utils/tool-qualification";
import { getToolDisplayChips } from "../../utils/tool-taxonomy";
import Pill from "./Pill.astro";

interface Props {
	postId: string;
	pubDate: Date;
	author: string;
	section?: "blog" | "outils" | "tutos" | "parcours";
	toolQualification?: ToolQualification;
	toolCategoryPrimary?: string;
	toolSubcategoryPrimary?: string;
	toolFacets?: string[];
}

const {
	postId,
	pubDate,
	author,
	section,
	toolQualification,
	toolCategoryPrimary,
	toolSubcategoryPrimary,
	toolFacets,
} = Astro.props;
const worldIcons = {
	charbon: "/world/charbon.svg",
	mine: "/world/mine.svg",
	or: "/world/or.svg",
};
const toolDisplayChips = getToolDisplayChips({
	id: postId,
	data: {
		section,
		toolCategoryPrimary,
		toolSubcategoryPrimary,
		toolFacets,
	},
});
---

<article
	class="post-content prose prose-lg md:prose-xl prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:mt-2 md:prose-h2:mt-6 prose-h2:mb-2 md:prose-h2:mb-4 prose-slate w-full max-w-full poppins p-4 md:p-6 rounded-lg bg-white dark:bg-black dark:prose-dark"
>
	<a href="/" title="Retour" class="hover:text-primary dark:hover:text-yellow-gold"
		>&larr; Retour</a
	>
	<div class="mine-icon-belt post-world-cues" aria-label="Progression Charbon vers Or">
		<span class="mine-icon-chip">
			<img src={worldIcons.charbon} alt="" aria-hidden="true" loading="lazy" />
			Repère
		</span>
		<span class="mine-icon-chip mine">
			<img src={worldIcons.mine} alt="" aria-hidden="true" loading="lazy" />
			Approfondir
		</span>
		<span class="mine-icon-chip or">
			<img src={worldIcons.or} alt="" aria-hidden="true" loading="lazy" />
			Passer à l'action
		</span>
	</div>
	<p class="text-base md:text-lg">
		Publié le {pubDate} par {author}
	</p>
	{section === "outils" && toolDisplayChips.length > 0 && (
		<ul class="tool-taxonomy-list">
			{toolDisplayChips.map((chip) => (
				<li>
					{chip.href ? (
						<a href={chip.href}>
							<Pill>{chip.label}</Pill>
						</a>
					) : (
						<Pill>{chip.label}</Pill>
					)}
				</li>
			))}
		</ul>
	)}
	{section === "outils" && <ToolQualificationCard metadata={toolQualification} />}
	<div>
		<slot />
	</div>
	<p>
		Écrit par {author}
	</p>
	<a href="/" title="Retour" class="hover:text-primary dark:hover:text-yellow-gold"
		>&larr; Retour</a
	>
</article>

<style>
	.post-content {
		border: 3px solid var(--brand-black);
		box-shadow: 6px 6px 0 var(--brand-black);
		background: linear-gradient(180deg, #fff7df 0%, #fff1cb 100%);
	}

	:global(.dark) .post-content {
		border-color: var(--brand-cream);
		box-shadow: 6px 6px 0 var(--brand-cream);
		background: linear-gradient(180deg, #141414 0%, #0f0f0f 100%);
	}

	.post-world-cues {
		margin: 0.65rem 0 0.85rem;
	}

	.tool-taxonomy-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 1rem 0;
		padding: 0;
		list-style: none;
	}

	article :global(h1) {
		font-size: 1.5rem;
		margin-top: 1rem;
		margin-bottom: 0.5rem;
	}

	article :global(h2) {
		font-size: 1.25rem;
		margin-top: 1rem;
		margin-bottom: 0.5rem;
		border: 2px solid var(--brand-black);
		background: linear-gradient(90deg, #f6c700 0 15%, #ffeab5 15% 100%);
		padding: 0.25rem 0.5rem;
		box-shadow: 3px 3px 0 var(--brand-black);
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	:global(.dark) article :global(h2) {
		border-color: var(--brand-cream);
		background: linear-gradient(90deg, #5f4a00 0 15%, #1b1b1b 15% 100%);
		box-shadow: 3px 3px 0 var(--brand-cream);
	}

	article :global(ul li)::marker {
		color: var(--brand-orange);
	}

	article :global(ol li)::marker {
		color: var(--brand-black);
		font-weight: 800;
	}

	:global(.dark) article :global(ul li)::marker,
	:global(.dark) article :global(ol li)::marker {
		color: var(--brand-yellow);
	}

	article :global(blockquote) {
		border-left: 4px solid var(--brand-black);
		background: rgb(255 255 255 / 55%);
		padding: 0.45rem 0.65rem;
	}

	:global(.dark) article :global(blockquote) {
		border-left-color: var(--brand-yellow);
		background: rgb(255 255 255 / 7%);
	}

	@media (min-width: 768px) {
		article :global(h1) {
			font-size: 1.875rem;
			margin-top: 2rem;
			margin-bottom: 1rem;
		}

		article :global(h2) {
			font-size: 1.5rem;
			margin-top: 2rem;
			margin-bottom: 1rem;
		}
	}
</style>
