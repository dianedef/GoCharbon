---
import ThemeToggle from "./ThemeToggle.astro";
import { Breadcrumbs } from "astro-breadcrumbs";
import "astro-breadcrumbs/breadcrumbs.css";
import { Home, ChevronRight } from "lucide-astro";
import { breadcrumbsConfig } from "../../config/breadcrumbs";
import { SITE } from "../../config/site";
import { ROUTES } from "../../config/routes";
import { isParcoursOnlyBuild } from "../../utils/build-scope";
import type {
	BaseNavigationProps,
	NavigationItem,
	SocialLink,
} from "../../utils/types/ui";

type Props = BaseNavigationProps;

const launchBuild = isParcoursOnlyBuild();
const navigationItems: NavigationItem[] = launchBuild
	? [{ name: "Parcours", url: ROUTES.parcours }]
	: [
		{ name: "Parcours", url: ROUTES.parcours },
		{ name: "Outils", url: ROUTES.outils },
		{ name: "Blog", url: ROUTES.blog },
		{ name: "Tutos", url: ROUTES.tutos },
		{ name: "Progression", url: ROUTES.progression },
	];

const socialIcons: SocialLink[] = [
	{
		name: "YouTube",
		url: SITE.social.youtube,
		icon: "i-uil-youtube",
	},
	{
		name: "Twitter",
		url: SITE.social.x,
		icon: "i-uil-twitter",
	},
	{
		name: "Instagram",
		url: SITE.social.instagram,
		icon: "i-uil-instagram",
	},
	{
		name: "LinkedIn",
		url: SITE.social.linkedin,
		icon: "i-uil-linkedin",
	},
	{
		name: "Facebook",
		url: SITE.social.facebook,
		icon: "i-uil-facebook",
	},
];

if (!launchBuild) {
	socialIcons.push({ name: "RSS", url: ROUTES.feed, icon: "i-uil-rss" });
}

const { pageTitle } = Astro.props;
const worldIcons = {
	charbon: "/world/charbon.svg",
	mine: "/world/mine.svg",
	or: "/world/or.svg",
};
---

<style define:vars={{ softWhite: 'var(--brand-cream)' }}>
	header {
		border-bottom: 4px solid var(--brand-black);
		background-color: var(--brand-cream);
		position: sticky;
		top: 0;
		z-index: 40;
	}

	:global(.dark) header {
		border-color: var(--softWhite);
		background-color: var(--brand-ink);
		color: var(--softWhite);
	}

	.mobile-link {
		color: var(--brand-black);
	}

	:global(.dark) .mobile-link {
		color: var(--softWhite);
	}

	:global(.breadcrumbs) {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
	}

	:global(.breadcrumbs a) {
		display: flex;
		align-items: center;
		color: inherit;
		text-decoration: none;
	}

	:global(.breadcrumbs a:hover) {
		color: var(--accent-color);
		text-decoration: underline;
	}

	.world-cues {
		margin-left: 0.35rem;
	}

	@media (max-width: 767px) {
		.world-cues {
			display: none;
		}
	}
</style>

<header class="flex flex-col px-4 py-3 md:px-6 md:py-4">
	<div class="flex justify-between items-center">
		{pageTitle && <h1 class="hidden">{pageTitle}</h1>}
		<div class="flex items-center gap-4">
			<a
				href="/"
				title="Retour à l'accueil"
				aria-label="Retour à l'accueil"
				class="inline-block cursor-pointer z-10 relative"
			>
				<span class="righteous text-3xl md:text-5xl text-black dark:text-yellow-soft">{SITE.nameUpper}</span>
			</a>
			<Breadcrumbs {...breadcrumbsConfig}>
				<Home slot="home" class="w-5 h-5" />
				<ChevronRight slot="separator" class="w-4 h-4" />
			</Breadcrumbs>
				<div class="mine-icon-belt world-cues" aria-label="Repères du monde GoCharbon">
					<span class="mine-icon-chip">
						<img src={worldIcons.charbon} alt="" aria-hidden="true" loading="lazy" />
						Charbon
					</span>
					<span class="mine-icon-chip mine">
						<img src={worldIcons.mine} alt="" aria-hidden="true" loading="lazy" />
						Mine
					</span>
					<span class="mine-icon-chip or">
						<img src={worldIcons.or} alt="" aria-hidden="true" loading="lazy" />
						Or
					</span>
				</div>
		</div>
		<nav class="hidden md:inline-block">
			<h2 class="hidden">Navigation</h2>
			<ul class="flex gap-6 poppins items-center">
					{
						navigationItems.map((item) => (
							<li>
								<a
									class="text-lg font-medium hover:underline transition-all duration-150 ease-in-out"
									href={item.url}
									title={`Go to ${item.name}`}
								>
									{item.name}
								</a>
							</li>
					))
				}
				{
					socialIcons.map((item) => (
						<li>
							<a
								href={item.url}
								target="_blank"
								title={`Voir ${SITE.name} sur ${item.name}`}
							>
								<div
									class:list={[item.icon, "w-6 h-6 md:w-7 md:h-7"]}
								/>
							</a>
						</li>
					))
				}
				<li>
					<ThemeToggle />
				</li>
			</ul>
		</nav>
		<nav class="md:hidden flex items-center gap-3">
			<h2 class="hidden">Mobile Navigation</h2>
			<ThemeToggle />
			<button
				id="mobile-menu-btn"
				class="p-2 border-2 border-black dark:border-yellow-soft rounded"
				aria-label="Ouvrir le menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					<path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		</nav>
	</div>
	<!-- Mobile menu panel -->
	<div id="mobile-menu" class="md:hidden hidden border-t-2 border-black dark:border-yellow-soft px-4 py-4">
		<div class="mine-icon-belt mb-4" aria-label="Repères du monde GoCharbon">
			<span class="mine-icon-chip">
				<img src={worldIcons.charbon} alt="" aria-hidden="true" loading="lazy" />
				Charbon
			</span>
			<span class="mine-icon-chip mine">
				<img src={worldIcons.mine} alt="" aria-hidden="true" loading="lazy" />
				Mine
			</span>
			<span class="mine-icon-chip or">
				<img src={worldIcons.or} alt="" aria-hidden="true" loading="lazy" />
				Or
			</span>
		</div>
		<ul class="flex flex-col gap-4 poppins">
			{
				navigationItems.map((item) => (
					<li>
						<a
							class="mobile-link text-lg font-medium block py-2"
							href={item.url}
						>
							{item.name}
						</a>
					</li>
				))
			}
		</ul>
		<div class="border-t border-black/20 dark:border-white/20 my-3"></div>
		<ul class="flex flex-wrap gap-4">
			{
				socialIcons.map((item) => (
					<li>
						<a
							href={item.url}
							target="_blank"
							rel="noopener noreferrer"
							title={`Voir ${SITE.name} sur ${item.name}`}
							class="mobile-link"
						>
							<div class:list={[item.icon, "w-7 h-7"]} />
						</a>
					</li>
				))
			}
		</ul>
	</div>
</header>

<script>
	const initMobileMenu = () => {
		const btn = document.getElementById("mobile-menu-btn");
		const menu = document.getElementById("mobile-menu");
		const hamburgerIcon = document.getElementById("hamburger-icon");
		const closeIcon = document.getElementById("close-icon");
		const mobileLinks = menu?.querySelectorAll('a[href^="/"]');

		if (!btn || !menu || btn.dataset.mobileMenuInit === "true") return;
		btn.dataset.mobileMenuInit = "true";

		btn.addEventListener("click", () => {
			const isOpen = menu.classList.toggle("hidden") === false;
			btn.setAttribute("aria-expanded", String(isOpen));
			btn.setAttribute("aria-label", isOpen ? "Fermer le menu" : "Ouvrir le menu");
			hamburgerIcon?.classList.toggle("hidden", isOpen);
			closeIcon?.classList.toggle("hidden", !isOpen);
		});

		mobileLinks?.forEach((link) => {
			link.addEventListener("click", () => {
				menu.classList.add("hidden");
				btn.setAttribute("aria-expanded", "false");
				btn.setAttribute("aria-label", "Ouvrir le menu");
				hamburgerIcon?.classList.remove("hidden");
				closeIcon?.classList.add("hidden");
			});
		});
	};

	initMobileMenu();
	document.addEventListener("astro:page-load", initMobileMenu);
	document.addEventListener("astro:after-swap", initMobileMenu);
	document.addEventListener("DOMContentLoaded", initMobileMenu);
</script>
