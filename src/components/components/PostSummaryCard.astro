---
import type { PostSummaryCardProps } from "../../utils/types/content";
import Card from "./Card.astro";
import Button from "./Button.astro";
import Pill from "./Pill.astro";
import EngagementBadge from "./EngagementBadge.astro";
import { Image } from "astro:assets";
import { extractMainTags, getMainTagLabel } from "../../utils/tag-groups";
import { computeEngagementBadge } from "../../utils/tool-qualification";
import { getToolDisplayChips } from "../../utils/tool-taxonomy";

type Props = PostSummaryCardProps;

const { post, index = 0 } = Astro.props;
const { data } = post;
const isInitialLoad = index < 2;
const mainTags = extractMainTags(data.tags).slice(0, 2);
const isToolPost = data.section === "outils";
const toolDisplayChips = getToolDisplayChips({ id: post.id, data });
const engagementBadge = isToolPost
	? computeEngagementBadge({
		qualificationLocale: data.qualificationLocale,
		ancrageEconomique: data.ancrageEconomique,
		niveauResponsabilite: data.niveauResponsabilite,
		paysSiege: data.paysSiege,
		paysFiscal: data.paysFiscal,
		paysFondateurs: data.paysFondateurs,
		hebergementDonnees: data.hebergementDonnees,
		societeMere: data.societeMere,
		sourcesVerification: data.sourcesVerification,
		notesQualification: data.notesQualification,
		methodologieVersion: data.methodologieVersion,
	  })
	: null;
/* 
console.log("PostSummaryCard reçoit:", {
	postId: post.id,
	postData: data,
	index,
	isInitialLoad,
});
 */
// Couleur fixe pour les boutons : violet clair (primaire)
const buttonColor = 'var(--brand-copper)';
---

<style define:vars={{ softWhite: 'var(--brand-cream)' }}>
	.post-title {
		color: var(--brand-black);
	}

	:global(.dark) .post-title {
		color: var(--softWhite);
	}

	.post-description {
		color: var(--brand-black);
	}

	:global(.dark) .post-description {
		color: var(--softWhite);
	}

	.post-image-container {
		border-color: var(--brand-black);
	}

	:global(.dark) .post-image-container {
		border-color: var(--softWhite);
	}

	.draft-badge {
		border-color: var(--brand-black);
	}

	:global(.dark) .draft-badge {
		color: var(--softWhite);
		border-color: var(--softWhite);
	}
</style>

<div>
	<Card color="var(--brand-cream)">
		<div class="p-4 rounded-lg transition-colors dark:bg-black">
			<h3
				class="post-title poppins text-3xl md:text-4xl font-bold"
			>
				{data.title}
			</h3>
			<div
				class="post-image-container rounded-lg border-3 my-4 h-56 overflow-hidden"
			>
				<Image
					src={data.imgUrl}
					alt={data.description}
					width={800}
					height={400}
					loading={isInitialLoad ? "eager" : "lazy"}
					decoding={isInitialLoad ? "sync" : "async"}
					class="rounded h-full w-full object-cover"
				/>
			</div>
			<p class="post-description poppins text-xl md:text-2xl leading-relaxed">
				{data.description}
			</p>
			{engagementBadge && (
				<div class="my-4">
					<EngagementBadge badge={engagementBadge} compact />
				</div>
			)}

			<div class="flex justify-end my-4">
				<div
					class="transition-colors hover:bg-white-soft dark:hover:bg-black rounded-lg"
				>
					<Button
						href={`/${post.id}`}
						color={buttonColor}
					>
						<span>Lire plus &rarr;</span>
					</Button>
				</div>
			</div>

			<div class="hidden sm:inline-block">
				<div class="flex justify-between items-center">
						<ul class="flex flex-wrap gap-4 mt-2">
							{isToolPost
								? toolDisplayChips.map((chip) => (
									<li>
										{chip.href ? (
											<a
												class="sanchez"
												href={chip.href}
											>
												<Pill>{chip.label}</Pill>
											</a>
										) : (
											<Pill>{chip.label}</Pill>
										)}
									</li>
								))
								: mainTags.map((mainTag) => (
									<li>
										<a
											class="sanchez"
											href={`/tag/${encodeURIComponent(mainTag)}`}
										>
											<Pill>{getMainTagLabel(mainTag)}</Pill>
										</a>
									</li>
								))}
						</ul>
					{
						data.draft && (
							<span class="draft-badge bg-primary rounded-full border-2 py-1 px-4 text-sm card-shadow">
								Brouillon
							</span>
						)
					}
				</div>
			</div>
		</div>
	</Card>
</div>
