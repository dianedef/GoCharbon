---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Default.astro";
import FilterTags from "../../../components/components/FilterTags.vue";
import PostGrid from "../../../components/components/PostGrid.astro";
import { toPostPreviews } from "../../../utils/post-preview";
import { MAIN_TAGS, getMainTagLabel } from "../../../utils/tag-groups";

export async function getStaticPaths() {
	// Archive pagination is intentionally disabled to keep the tag surface focused.
	// Canonical archive entrypoints are /tag/[tag] only.
	return [];
}

const { tag, posts } = Astro.props;
const isToolTag = tag === "outils";
const mainTags = isToolTag ? ["outils"] : MAIN_TAGS;
const selectedTags = [tag];
const clientPosts = toPostPreviews(posts);
const tagLabel = getMainTagLabel(tag);
---

<Layout
	title={`Tag ${tagLabel} | GoCharbon`}
	description={`Explore les contenus GoCharbon lies a ${tagLabel}.`}
	pageTitle={`Tag ${tagLabel}`}
	metaRobots="noindex, follow"
>
	<main
		class="page-background bg-gray-2 dark:bg-gray-8 p-6"
		transition:name="posts-container"
	>
			<FilterTags
				mainTags={mainTags}
				initialPosts={clientPosts}
				selectedTags={selectedTags}
				scope={isToolTag ? "outils" : "all"}
				client:visible
			/>
		{
			posts.length > 0 ? (
				<div>
					<div
						id="selected-tags"
						data-tags={selectedTags.join(",")}
						class="hidden"
					/>
					<PostGrid posts={posts} showLoadingSpinner={true} />
				</div>
			) : (
				<p class="text-center py-10">
					Aucun post trouvé pour le tag {tagLabel}
				</p>
			)
		}
	</main>
</Layout>
