---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Default.astro";
import FilterTags from "../../components/components/FilterTags.vue";
import { toPostPreviews } from "../../utils/post-preview";
import { MAIN_TAGS, extractMainTags, getMainTagLabel } from "../../utils/tag-groups";
import { filterBuildVisiblePosts } from "../../utils/build-posts";

export async function getStaticPaths() {
	const allPosts = filterBuildVisiblePosts(await getCollection("posts"));
	const paths = [];

	for (const mainTag of MAIN_TAGS) {
		const filteredPosts = allPosts
			.filter((post) => extractMainTags(post.data.tags).includes(mainTag))
			.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

		if (!filteredPosts.length) continue;

		paths.push({
			params: { tag: mainTag },
			props: {
				posts: toPostPreviews(filteredPosts.slice(0, 15)),
				tag: mainTag,
			},
		});
	}

	return paths;
}

const { posts, tag } = Astro.props;
const mainTags = MAIN_TAGS;
const selectedTags = [tag];
const tagLabel = getMainTagLabel(tag);
---

<Layout
	title={`Posts - ${tagLabel}`}
	description={`GOCHARBON | Posts tagged with ${tagLabel}`}
	pageTitle={`Posts - ${tagLabel}`}
	metaRobots="index, follow"
>
	<main
		class="page-background bg-white-soft dark:bg-black p-6"
		transition:name="posts-container"
	>
		<FilterTags
			mainTags={mainTags}
			initialPosts={posts}
			selectedTags={selectedTags}
			client:visible
		/>
		{
			posts.length === 0 && (
				<p class="text-center py-10">
					Aucun post trouvé pour le tag{" "}
					{tagLabel}
				</p>
			)
		}
	</main>
</Layout>
