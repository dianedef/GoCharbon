---
import Layout from "../layouts/Default.astro";
import CharbonGamificationDashboard from "../components/vue/CharbonGamificationDashboard.vue";
---

<Layout
	title="Progression - GOCHARBON"
	description="Suis ta progression GoCharbon : XP, badges, series de lecture et parcours completes."
	pageTitle="Progression"
>
	<main class="min-h-screen py-12 md:py-20">
		<div class="container mx-auto px-4 max-w-6xl">
			<div class="text-center mb-10">
				<h1 class="text-4xl md:text-5xl font-bold mb-4 poppins text-black dark:text-yellow-soft">
					Ta Progression
				</h1>
				<p class="text-lg md:text-xl text-black dark:text-white">
					XP, badges, series et parcours — tout ton avancement en un coup d'oeil.
				</p>
			</div>
			<CharbonGamificationDashboard client:load />
		</div>
	</main>
</Layout>
