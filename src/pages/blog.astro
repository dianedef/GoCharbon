---
import { getCollection } from "astro:content";
import Layout from "../layouts/Default.astro";
import FilterTags from "../components/components/FilterTags.vue";
import { tagHierarchy } from "../components/tagHierarchy";
import { applyContentScope } from "../utils/content-section";
import { toPostPreviews } from "../utils/post-preview";

// Récupération des posts initiaux pour le SSG
const allPosts = await getCollection("posts");
const blogPosts = applyContentScope(allPosts, "blog");

const initialPosts = blogPosts
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 15);
const initialPostPreviews = toPostPreviews(initialPosts);

const mainTags = Object.keys(tagHierarchy);
---

<Layout title="Blog" description="Découvre tous les articles GOCHARBON : business, marketing, tech, SEO et productivité pour entrepreneurs et freelances. Conseils pratiques et stratégies actionnables." pageTitle="Blog GOCHARBON">
	<main class="px-2 md:px-6 py-6 max-w-7xl mx-auto">
		<!-- Zone de contenu dynamique -->
			<div id="dynamic-content">
				<!-- Composant Vue pour le filtrage -->
				<FilterTags
					client:visible
					mainTags={mainTags}
					initialPosts={initialPostPreviews}
					scope="blog"
				/>
			</div>
	</main>
</Layout>

<style>
	.page-background {
		transition: background-color 0.3s ease;
	}
</style>
