---
import Layout from "../layouts/Default.astro";
import Quiz from "../components/vue/Quiz.vue";
import { quizQuickData } from "../data/quizQuickData.js";
import { getParcoursSlug } from "../data/parcoursSlugs";
import {
  CANONICAL_ARCHETYPES,
  getArchetypeDefinition,
  getFeaturedProfilesForArchetype,
  type CanonicalArchetype,
} from "../data/profileTaxonomy";
import { getCollection } from "astro:content";
import { getParcoursRoute } from "../config/routes";

const profileToEntryId = Object.fromEntries(
  CANONICAL_ARCHETYPES.map((archetype) => [
    archetype,
    `biz/profils/${getArchetypeDefinition(archetype).pivotProfileSlug}`,
  ])
) as Record<CanonicalArchetype, string>;

const profileToLearningPathId = Object.fromEntries(
  CANONICAL_ARCHETYPES.map((archetype) => [
    archetype,
    getArchetypeDefinition(archetype).pivotProfileSlug,
  ])
) as Record<CanonicalArchetype, string>;

const featuredEntryIds = CANONICAL_ARCHETYPES.flatMap((archetype) =>
  getFeaturedProfilesForArchetype(archetype).map((profile) => `biz/profils/${profile.profileSlug}`)
);

const requiredIds = new Set([...Object.values(profileToEntryId), ...featuredEntryIds]);
const bizEntries = await getCollection("posts", ({ id }) => requiredIds.has(id));

const quizBizProfiles = Object.fromEntries(
  Object.entries(profileToEntryId).map(([profileKey, entryId]) => {
    const entry = bizEntries.find((item) => item.id === entryId);
    const learningPathId = profileToLearningPathId[profileKey as CanonicalArchetype];
    return [
      profileKey,
      entry
        ? {
            title: entry.data.title,
            description: entry.data.description,
            slug: `/${entry.id}`,
            tags: entry.data.tags,
            learningPathId,
            learningPathUrl: getParcoursRoute(learningPathId),
            relatedProfiles: getFeaturedProfilesForArchetype(profileKey as CanonicalArchetype).map((profile) => {
              const relatedEntryId = `biz/profils/${profile.profileSlug}`;
              const relatedEntry = bizEntries.find((item) => item.id === relatedEntryId);
              return {
                title: relatedEntry?.data.title ?? profile.title,
                description: relatedEntry?.data.description ?? "",
                slug: relatedEntry ? `/${relatedEntry.id}` : `/biz/profils/${profile.profileSlug}`,
                learningPathId: profile.profileSlug,
                learningPathUrl: getParcoursRoute(profile.profileSlug),
              };
            }),
          }
        : null,
    ];
  })
);
---

<Layout
  title="Quiz Business Rapide - 2 min | GOCHARBON"
  description="Quiz business rapide en 2 minutes pour obtenir une direction immédiate et ton top 2 modèles business en ligne."
  pageTitle="Quiz Business Rapide"
>
  <main class="min-h-screen bg-yellow-soft dark:bg-black py-12 md:py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-8 md:mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-4 poppins text-black dark:text-yellow-soft">
            Quiz Business Rapide
          </h1>
          <p class="text-lg md:text-xl text-gray-700 dark:text-gray-300">
            2 minutes pour trouver ta meilleure direction business
          </p>
        </div>

        <Quiz client:load bizProfiles={quizBizProfiles} data={quizQuickData} mode="quick" />
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1280px;
  }
</style>
