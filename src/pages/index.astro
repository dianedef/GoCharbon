---
import Layout from "../layouts/Default.astro";
import Button from "../components/components/Button.astro";
import GoCharbonShortcuts from "../components/GoCharbonShortcuts.astro";
import SentenceQuiz from "../components/vue/SentenceQuiz.vue";
import { getCollection } from "astro:content";
import { filterBuildVisiblePosts } from "../utils/build-posts";
import { filterLaunchParcours, isParcoursOnlyBuild } from "../utils/build-scope";
import { learningPaths } from "../data/parcoursData";
import { launchSignals } from "../data/launchSignals";
import { charbonBadges } from "../gamification/config";
import { ROUTES, getParcoursRoute } from "../config/routes";

const allPosts = filterBuildVisiblePosts(await getCollection("posts"));
const launchBuild = isParcoursOnlyBuild();
const visiblePaths = launchBuild ? filterLaunchParcours(learningPaths) : learningPaths;

const totalPaths = visiblePaths.length;
const totalModules = visiblePaths.reduce((sum, path) => sum + path.modules.length, 0);
const totalSteps = visiblePaths.reduce(
  (sum, path) => sum + path.modules.reduce((moduleSum, module) => moduleSum + module.steps.length, 0),
  0,
);
const averageSteps = Math.round(totalSteps / totalPaths);
const totalBadges = charbonBadges.length;

const popularPathIds = ["freelance", "testeur-utilisateur", "ecommerce", "content-creator", "formation"];
const popularPaths = popularPathIds
  .map((id) => visiblePaths.find((path) => path.id === id))
  .filter((path): path is NonNullable<typeof path> => path != null);

const entryPoints = [
  {
    label: "Vendre un service vite",
    title: "Freelance / conseil / agence",
    description: "Pour partir d’une compétence, trouver des premiers clients et structurer une offre simple.",
    examples: "Exemples : copywriter, assistant virtuel, testeur utilisateur, SEO freelance",
    href: getParcoursRoute("freelance"),
  },
  {
    label: "Revenu annexe cadré",
    title: "Tests utilisateurs / crowdtesting",
    description: "Pour démarrer petit, comprendre vite le terrain et transformer un revenu d’appoint en porte d’entrée vers un service plus structuré.",
    examples: "Exemples : crowdtesting, études rémunérées, missions simples avant une offre freelance plus carrée",
    href: getParcoursRoute("testeur-utilisateur"),
  },
  {
    label: "Construire une audience",
    title: "Contenu / newsletter / activité de créateur",
    description: "Pour avancer avec le contenu, la réputation, la monétisation et un système éditorial tenable.",
    examples: "Exemples : YouTube, newsletter, blog, affiliation",
    href: getParcoursRoute("content-creator"),
  },
  {
    label: "Monter un produit",
    title: launchBuild ? "E-commerce / formation" : "E-commerce / SaaS / formation",
    description: "Pour tester une offre, choisir la bonne structure et poser un vrai chemin de conversion.",
    examples: launchBuild
      ? "Exemples : e-commerce, formation en ligne, offre simple monétisable"
      : "Exemples : e-commerce, SaaS, formation en ligne, live commerce comme angle produit",
    href: getParcoursRoute("ecommerce"),
  },
];

const productPreview = {
  profile: visiblePaths.find((path) => path.id === "ecommerce") ?? popularPaths[0],
  progressPercent: 39,
  xp: 180,
  completedSteps: 5,
  totalSteps: 13,
};
const homeTitle = launchBuild
  ? "GoCharbon - Parcours business pour lancer ton activité"
  : "GoCharbon - Quiz, parcours et progression pour lancer ton business";
const homeDescription = launchBuild
  ? "Cinq parcours pilotes pour lancer une activité crédible, avancer étape par étape et garder des repères utiles."
  : "Trouve un business adapté à ton profil, reçois un parcours concret et avance avec des checklists, de la progression et des outils francophones.";
---

<Layout
  title={homeTitle}
  description={homeDescription}
  pageTitle="GOCHARBON"
>
  <main class="home-shell min-h-screen">
    <section class="hero-section bg-yellow-primary dark:bg-yellow-dark">
      <div class="hero-grid px-6 py-12 md:py-18 max-w-6xl mx-auto">
        <div class="hero-copy">
          <p class="hero-kicker poppins">PAS UN ÉNIÈME BLOG BUSINESS</p>
          <h1 class="hero-title poppins">
            Trouve un modèle crédible.
            <span>Reçois un parcours.</span>
            <span>Coche chaque étape.</span>
          </h1>
          <p class="hero-intro">
            {launchBuild
              ? "GoCharbon part petit exprès : cinq parcours pilotes relus à la main, quatre portes d’entrée simples, et un seul objectif sérieux, te faire passer du flou à un premier signal terrain."
              : "GoCharbon transforme la théorie en exécution : un quiz pour t'orienter, un parcours pour savoir quoi faire, puis une progression visible pour tenir dans la durée."}
          </p>
          <div class="hero-points">
            <div class="hero-point">
              <strong>{totalPaths} parcours</strong>
              <span>{launchBuild ? "pilotes, assumés et relus avant d'ouvrir plus large" : "pour partir d'un profil réel, pas d'un fantasme de business"}</span>
            </div>
            <div class="hero-point">
              <strong>{averageSteps} étapes en moyenne</strong>
              <span>pour transformer "je me renseigne" en "j'avance vraiment"</span>
            </div>
            <div class="hero-point">
              <strong>Progression sauvegardée</strong>
              <span>{launchBuild ? "modules, checklists, XP, repères concrets" : "XP, badges, modules, repères concrets"}</span>
            </div>
          </div>
          <div class="hero-actions">
            <Button href={ROUTES.parcours} color="var(--brand-orange)" variant="hero">
              Voir les parcours
            </Button>
            <Button href={launchBuild ? "#entry-points" : ROUTES.quiz} color="var(--brand-yellow)" variant="hero">
              {launchBuild ? "Choisir une porte d’entrée" : "Faire le quiz"}
            </Button>
          </div>
          <p class="hero-note">
            {launchBuild
              ? "Si tu pars de zéro, commence par une porte d’entrée. Si tu sais déjà quel modèle tu veux tester, ouvre directement le parcours correspondant."
              : "Si tu pars de zéro : commence par le quiz. Si tu sais déjà ce que tu veux vendre : va directement sur les parcours."}
          </p>
        </div>

        <div class="hero-product">
          <div class="hero-panel hero-panel-quiz">
            <div class="panel-header">
              <p class="panel-kicker">Aperçu du système</p>
              <h2>{launchBuild ? "Entre par une famille claire avant de t'éparpiller." : "Choisis une direction avant de t'épuiser."}</h2>
            </div>
            {launchBuild ? (
              <>
                <p class="panel-copy">
                  Service, audience, produit ou revenu d’appoint : tu choisis une logique de départ, puis tu ouvres un parcours réellement travaillé. Le site démarre volontairement avec peu de pages, pour que chacune tienne debout.
                </p>
                <div class="hero-sentence-quiz">
                  <p class="hero-launch-summary">
                    4 entrées lisibles. {totalPaths} parcours pilotes. Une base plus petite, mais beaucoup plus nette.
                  </p>
                </div>
              </>
            ) : (
              <>
                <p class="panel-copy">
                  Le quiz ne te donne pas une vague idée. Il t'envoie vers un type de business et un plan d'action utilisable.
                </p>
                <div class="hero-sentence-quiz">
                  <SentenceQuiz client:visible />
                </div>
              </>
            )}
          </div>

          <div class="hero-panel hero-panel-preview">
            <div class="preview-topline">
              <span class="preview-chip">Parcours recommandé</span>
              <span class="preview-chip muted">Sauvegarde locale</span>
            </div>
            <h3>{productPreview.profile.profileTitle}</h3>
            <p>{productPreview.profile.outcome}</p>
            <div class="preview-progress">
              <div class="preview-progress-label">
                <span>Progression</span>
                <strong>{productPreview.progressPercent}%</strong>
              </div>
              <div class="preview-track">
                <div class="preview-fill" style={`width: ${productPreview.progressPercent}%`} />
              </div>
            </div>
            <div class="preview-stats">
              <div>
                <strong>{productPreview.completedSteps}/{productPreview.totalSteps}</strong>
                <span>étapes cochées</span>
              </div>
              <div>
                <strong>+{productPreview.xp} XP</strong>
                <span>cumulés</span>
              </div>
              <div>
                <strong>{totalBadges} badges</strong>
                <span>à débloquer</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="proof-section bg-white-soft dark:bg-black">
      <div class="px-6 py-14 max-w-6xl mx-auto">
        <div class="section-heading centered">
          <p class="section-kicker">CE QU'IL Y A VRAIMENT DERRIÈRE</p>
          <h2 class="section-title poppins">Un périmètre plus petit, mais des signaux beaucoup plus nets</h2>
          <p class="section-copy">
            Le lancement couvre seulement ce qu’on peut défendre proprement : vendre un service, tester un revenu d’appoint, construire une audience, lancer un produit ou transformer une expertise en formation.
          </p>
        </div>
        <div class="proof-grid">
          <article class="proof-card">
            <strong>{totalPaths}</strong>
            <span>parcours reliés à des profils business clairs</span>
          </article>
          <article class="proof-card">
            <strong>{totalModules}</strong>
            <span>modules pour passer des bases à l'exécution terrain</span>
          </article>
          <article class="proof-card">
            <strong>{totalSteps}</strong>
            <span>étapes actionnables déjà structurées dans le système</span>
          </article>
          <article class="proof-card">
            <strong>{launchBuild ? "1 focus" : `${allPosts.length}+`}</strong>
            <span>{launchBuild ? "cinq parcours pilotes assumés avant d'élargir le reste du site" : "guides, tutos et contenus pour te débloquer sans tourner en rond"}</span>
          </article>
        </div>
      </div>
    </section>

    {launchBuild && (
      <section class="signals-section bg-white-soft dark:bg-black">
        <div class="px-6 py-16 max-w-6xl mx-auto">
          <div class="section-heading">
            <p class="section-kicker">POURQUOI CES 5 LÀ D'ABORD</p>
            <h2 class="section-title poppins">On a ouvert d’abord les modèles où les repères sont les plus lisibles</h2>
            <p class="section-copy">
              L’idée n’est pas de tout couvrir dès le jour 1. L’idée est de commencer là où le lecteur peut prendre une décision plus propre, plus vite.
            </p>
          </div>
          <div class="entry-grid">
            {launchSignals.map((signal) => (
              <article class="entry-card">
                <p class="entry-label">{signal.kicker}</p>
                <h3>{signal.title}</h3>
                <p>{signal.description}</p>
                <div class="source-links" aria-label={`Sources pour ${signal.title}`}>
                  {signal.sources.map((source) => (
                    <a href={source.href} target="_blank" rel="noopener noreferrer">
                      {source.label}
                    </a>
                  ))}
                </div>
                <p class="entry-cta-row">
                  <a href={getParcoursRoute(signal.pathId)}>Ouvrir ce parcours →</a>
                </p>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="difference-section bg-purple-light dark:bg-purple-dark">
      <div class="px-6 py-16 max-w-6xl mx-auto">
        <div class="section-heading">
          <p class="section-kicker">POURQUOI ÇA TIENT MIEUX DANS LE TEMPS</p>
          <h2 class="section-title poppins">Choisir, exécuter, tenir : dans cet ordre-là</h2>
        </div>
        <div class="difference-grid">
          <article class="difference-card">
            <p class="difference-number">01</p>
            <h3>Orientation</h3>
            <p>
              {launchBuild
                ? "Tu commences par des portes d'entrée concrètes. Moins de confusion, moins de dispersion, plus de décision."
                : "Tu commences par un quiz et des portes d'entrée concrètes. Moins de confusion, moins de dispersion, plus de décision."}
            </p>
          </article>
          <article class="difference-card">
            <p class="difference-number">02</p>
            <h3>Exécution</h3>
            <p>
              Chaque parcours relie bases, spécialisation et plan 7 jours. Tu vois l'ordre des actions au lieu d'empiler des lectures.
            </p>
          </article>
          <article class="difference-card">
            <p class="difference-number">03</p>
            <h3>Motivation visible</h3>
            <p>
              Progression, XP, badges, séries : le site te pousse à terminer quelque chose, pas juste à consommer plus de contenu.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section id="entry-points" class="entry-section bg-white-soft dark:bg-black">
      <div class="px-6 py-16 max-w-6xl mx-auto">
        <div class="section-heading">
          <p class="section-kicker">CHOISIS TA PORTE D'ENTRÉE</p>
          <h2 class="section-title poppins">Commence par le type de machine que tu veux construire</h2>
          <p class="section-copy">
            Au lieu de tomber dans une page catalogue, entre par ton intention : vendre un service, construire une audience, monter un produit ou commencer par un revenu annexe utile.
          </p>
        </div>
        <div class="entry-grid">
          {entryPoints.map((entry) => (
            <a href={entry.href} class="entry-card no-link-style">
              <p class="entry-label">{entry.label}</p>
              <h3>{entry.title}</h3>
              <p>{entry.description}</p>
              <p class="entry-examples">{entry.examples}</p>
              <span>Ouvrir ce parcours →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="showcase-section bg-yellow-soft dark:bg-purple-darker">
      <div class="px-6 py-16 max-w-6xl mx-auto">
        <div class="section-heading">
          <p class="section-kicker">VOIS LE SYSTÈME AVANT D'ENTRER</p>
          <h2 class="section-title poppins">Tu sais ce que tu vas trouver avant même de cliquer</h2>
        </div>
        <div class="showcase-grid">
          <article class="showcase-card">
            <div class="showcase-card-head">
              <span class="showcase-chip">Parcours type</span>
              <strong>3 modules</strong>
            </div>
            <h3>{productPreview.profile.profileTitle}</h3>
            <p>{productPreview.profile.estimatedDuration}</p>
            <ul class="module-list">
              {productPreview.profile.modules.map((module, index) => (
                <li class:list={["module-item", index === 0 ? "done" : null]}>
                  <span class="module-mark">{index === 0 ? "✓" : index === 1 ? "•" : "→"}</span>
                  <div>
                    <strong>{module.title}</strong>
                    <p>{module.objective}</p>
                  </div>
                </li>
              ))}
            </ul>
            <div class="showcase-footer">
              <Button href={getParcoursRoute(productPreview.profile.id)} color="var(--brand-yellow)">
                Voir un vrai parcours
              </Button>
            </div>
          </article>

          <article class="showcase-card dashboard-card">
            <div class="showcase-card-head">
              <span class="showcase-chip">Progression</span>
              <strong>Ce que tu gardes sous les yeux</strong>
            </div>
            <div class="dashboard-grid">
              <div class="dashboard-stat">
                <strong>180 XP</strong>
                <span>momentum visible</span>
              </div>
              <div class="dashboard-stat">
                <strong>3 jours</strong>
                <span>série de lecture</span>
              </div>
              <div class="dashboard-stat">
                <strong>2 badges</strong>
                <span>premiers repères</span>
              </div>
              <div class="dashboard-stat">
                <strong>39%</strong>
                <span>parcours en cours</span>
              </div>
            </div>
            <div class="badge-row">
              <span>👣 Premier pas</span>
              <span>🔥 Régulier</span>
              <span>💼 Expert business</span>
            </div>
            <p class="dashboard-copy">
              L'idée n'est pas de te distraire avec de la gamification. L'idée, c'est de rendre visible ton avancée pour que tu tiennes assez longtemps pour voir des résultats.
            </p>
            <div class="showcase-footer dual">
              {launchBuild ? (
                <>
                  <Button href={ROUTES.parcours} color="var(--brand-orange)">
                    Voir tous les parcours
                  </Button>
                  <Button href="#entry-points" color="var(--brand-yellow)">
                    Revoir les portes d'entrée
                  </Button>
                </>
              ) : (
                <>
                  <Button href={ROUTES.progression} color="var(--brand-orange)">
                    Voir la progression
                  </Button>
                  <Button href={ROUTES.quizAvance} color="var(--brand-yellow)">
                    Affiner le quiz
                  </Button>
                </>
              )}
            </div>
          </article>
        </div>
      </div>
    </section>

    {!launchBuild && <GoCharbonShortcuts />}

    <section class="popular-section bg-white-soft dark:bg-black">
      <div class="px-6 py-16 max-w-6xl mx-auto">
        <div class="section-heading">
          <p class="section-kicker">PARCOURS PILOTES</p>
          <h2 class="section-title poppins">Les 5 parcours pilotes ouverts au lancement</h2>
          <p class="section-copy">
            Chacun a été resserré pour qu’un lecteur comprenne vite le modèle, les pièges, les chiffres à suivre et la première action à faire ce soir.
          </p>
        </div>
        <div class="popular-grid">
          {popularPaths.map((path) => (
            <a href={getParcoursRoute(path.id)} class="popular-card no-link-style">
              <p class="popular-category">{path.category}</p>
              <h3>{path.profileTitle}</h3>
              <p>{path.outcome}</p>
              <div class="popular-meta">
                <span>{path.modules.length} modules</span>
                <span>{path.estimatedDuration}</span>
              </div>
              <span class="popular-cta">Voir le parcours →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="founder-section bg-yellow-gold dark:bg-yellow-dark">
      <div class="px-6 py-16 max-w-6xl mx-auto founder-grid">
        <div class="founder-badge">
          <div class="founder-medallion">D</div>
          <p class="founder-tag">Fondatrice</p>
        </div>
        <div class="founder-copy">
          <p class="section-kicker">POURQUOI CE SITE EXISTE</p>
          <h2 class="section-title poppins">Diane construit le site qu’elle aurait voulu avoir au début</h2>
          <p>
            Je ne manque pas de contenus sur le business en ligne. J’en manque plutôt des bons. GoCharbon part de là : trop de bruit, trop de promesses molles, et pas assez de systèmes qui aident vraiment à choisir, avancer et tenir.
          </p>
          <p>
            Ici, je ne cherche pas à te noyer sous les frameworks. Je cherche à te donner un cap, des actions et des repères, pour que tu puisses enfin passer du scroll à l’exécution.
          </p>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .home-shell {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    overflow: clip;
  }

  .home-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at 15% 10%, rgb(255 255 255 / 0.35) 0 28%, transparent 60%);
    opacity: 0.32;
    z-index: -1;
  }

  .hero-grid,
  .founder-grid {
    display: grid;
    gap: 1.5rem;
  }

  .hero-grid {
    align-items: stretch;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
  }

  .hero-copy,
  .hero-product {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-kicker,
  .section-kicker {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .hero-title,
  .section-title {
    margin: 0;
    line-height: 0.96;
  }

  .hero-title {
    font-size: clamp(2.9rem, 6vw, 5.5rem);
    max-width: 11ch;
  }

  .hero-title span {
    display: block;
  }

  .hero-intro,
  .section-copy,
  .founder-copy p,
  .panel-copy,
  .dashboard-copy {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .hero-points {
    display: grid;
    gap: 0.75rem;
  }

  .hero-point,
  .hero-panel,
  .proof-card,
  .difference-card,
  .entry-card,
  .showcase-card,
  .popular-card {
    border: 3px solid var(--brand-black);
    background: rgb(245 245 242 / 0.92);
    box-shadow: 6px 6px 0 var(--brand-black);
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }

  .hero-point {
    display: grid;
    gap: 0.15rem;
    padding: 0.95rem 1rem;
  }

  .hero-point:hover,
  .hero-panel:hover,
  .proof-card:hover,
  .difference-card:hover,
  .entry-card:hover,
  .popular-card:hover,
  .showcase-card:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--brand-black);
  }

  .hero-point strong,
  .proof-card strong,
  .dashboard-stat strong,
  .preview-stats strong,
  .module-item strong,
  .entry-card h3,
  .popular-card h3 {
    font-family: "Poppins", sans-serif;
  }

  .hero-actions,
  .preview-stats,
  .proof-grid,
  .difference-grid,
  .entry-grid,
  .source-links,
  .popular-grid,
  .dashboard-grid {
    display: grid;
    gap: 1rem;
  }

  .hero-actions {
    grid-template-columns: repeat(2, minmax(0, max-content));
    align-items: center;
  }

  .hero-note {
    margin: 0;
    font-size: 0.98rem;
    opacity: 0.78;
  }

  .hero-panel {
    padding: 1.15rem;
    border-radius: 0.5rem;
  }

  .hero-panel-quiz {
    background:
      linear-gradient(145deg, rgb(255 255 255 / 0.6) 0%, rgb(246 199 0 / 0.24) 100%),
      var(--brand-cream);
  }

  .hero-panel-preview {
    background:
      linear-gradient(145deg, rgb(226 87 45 / 0.16) 0%, rgb(255 255 255 / 0.58) 100%),
      var(--brand-cream);
  }

  .panel-header {
    display: grid;
    gap: 0.35rem;
  }

  .panel-header h2,
  .hero-panel-preview h3 {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.1;
  }

  .hero-launch-summary {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.6;
    font-weight: 700;
  }

  .panel-kicker,
  .entry-label,
  .popular-category,
  .founder-tag {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-sentence-quiz {
    margin-top: 0.4rem;
  }

  .preview-topline,
  .showcase-card-head,
  .popular-meta,
  .preview-progress-label {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .preview-chip,
  .showcase-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.65rem;
    border: 2px solid currentColor;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .preview-chip.muted {
    opacity: 0.72;
  }

  .preview-progress {
    display: grid;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .preview-track {
    height: 14px;
