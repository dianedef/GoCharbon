---
const title = "GoCharbon | Links"
const description = "Tous les liens GoCharbon - Guides, outils et stratégies pour lancer ton business en ligne."
const siteUrl = "https://gocharbon.com"
---

<!DOCTYPE html>
<html lang="fr">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta name="robots" content="index, follow" />
	<link rel="canonical" href={`${siteUrl}/bio`} />

	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:url" content={`${siteUrl}/bio`} />
	<meta property="og:type" content="website" />
	<meta property="og:site_name" content="GoCharbon" />
	<meta property="og:locale" content="fr_FR" />

	<meta name="twitter:card" content="summary" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Sanchez&display=swap" rel="stylesheet" />

	<style>
		:root {
			--yellow-primary: #ffe001;
			--purple-bright: #9e4fff;
			--purple-dark: #5f13bb;
			--yellow-soft: #fff6d2;
		}

		* { margin: 0; padding: 0; box-sizing: border-box; }

		body {
			font-family: 'Sanchez', serif;
			background: #000;
			color: var(--yellow-soft);
			min-height: 100vh;
			display: flex;
			justify-content: center;
			padding: 2rem 1rem;
		}

		.bio-container {
			width: 100%;
			max-width: 480px;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
		}

		.bio-avatar {
			width: 96px;
			height: 96px;
			border-radius: 50%;
			border: 3px solid var(--yellow-primary);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 2.5rem;
			background: var(--purple-dark);
		}

		.bio-name {
			font-family: 'Poppins', sans-serif;
			font-size: 1.5rem;
			font-weight: 700;
			color: var(--yellow-primary);
			text-align: center;
		}

		.bio-tagline {
			font-size: 0.95rem;
			text-align: center;
			color: var(--yellow-soft);
			line-height: 1.5;
			max-width: 340px;
		}

		.bio-links {
			width: 100%;
			display: flex;
			flex-direction: column;
			gap: 0.75rem;
		}

		.bio-link {
			display: block;
			width: 100%;
			padding: 1rem 1.25rem;
			text-align: center;
			text-decoration: none;
			font-family: 'Poppins', sans-serif;
			font-weight: 600;
			font-size: 1rem;
			color: #000;
			background: var(--yellow-primary);
			border: 3px solid #000;
			filter: drop-shadow(4px 4px 0 var(--purple-bright));
			transition: all 0.2s ease;
		}

		.bio-link:hover {
			filter: drop-shadow(2px 2px 0 var(--purple-bright));
			transform: translate(2px, 2px);
		}

		.bio-link.accent {
			background: var(--purple-bright);
			color: #fff;
			filter: drop-shadow(4px 4px 0 var(--yellow-primary));
		}

		.bio-link.accent:hover {
			filter: drop-shadow(2px 2px 0 var(--yellow-primary));
			transform: translate(2px, 2px);
		}

		.bio-socials {
			display: flex;
			gap: 1.25rem;
			margin-top: 0.5rem;
		}

		.bio-socials a {
			color: var(--yellow-soft);
			transition: color 0.2s ease;
		}

		.bio-socials a:hover {
			color: var(--yellow-primary);
		}

		.bio-socials svg {
			width: 28px;
			height: 28px;
		}

		.bio-footer {
			font-size: 0.8rem;
			color: var(--yellow-soft);
			opacity: 0.6;
			margin-top: 1rem;
		}
	</style>
</head>
<body>
	<div class="bio-container">
		<div class="bio-avatar">
			<span>&#x1F469;&#x200D;&#x1F4BB;</span>
		</div>

		<h1 class="bio-name">GOCHARBON</h1>

		<p class="bio-tagline">
			Lance ton business en ligne. Guides concrets, outils testés, zéro bullshit.
		</p>

		<div class="bio-links">
			<a href="https://gocharbon.com" class="bio-link">Accueil</a>
			<a href="https://gocharbon.com/blog" class="bio-link">Blog</a>
			<a href="https://gocharbon.com/quiz" class="bio-link">Quiz : Trouve Ton Business</a>
			<a href="https://gocharbon.com/blog?tags=apps" class="bio-link">Apps & Outils</a>
			<a href="https://gocharbon.com/blog?tags=productivite" class="bio-link">Gamification & Productivité</a>
			<a href="https://gocharbon.com/#newsletter" class="bio-link accent">Reçois le Guide Gratuit</a>
		</div>

		<div class="bio-socials">
			<!-- Twitter/X -->
			<a href="https://x.com/gocharbon" aria-label="Twitter / X" rel="noopener noreferrer" target="_blank">
