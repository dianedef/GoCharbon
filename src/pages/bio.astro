---
import { SITE, getSiteUrl } from "../config/site";
import { ROUTES, getBlogTagRoute } from "../config/routes";

const title = `${SITE.name} | Diane`
const description = `Diane construit ${SITE.name} pour aider les francophones à lancer des projets utiles, solides et moins bullshit.`
const siteUrl = SITE.url
---

<!DOCTYPE html>
<html lang="fr">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta name="robots" content="index, follow" />
	<link rel="canonical" href={`${siteUrl}/bio`} />

	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:url" content={`${siteUrl}/bio`} />
	<meta property="og:type" content="website" />
	<meta property="og:site_name" content={SITE.name} />
	<meta property="og:locale" content="fr_FR" />

	<meta property="og:image" content={`${siteUrl}/v1/generate/og/default.png`} />

	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:image" content={`${siteUrl}/v1/generate/og/default.png`} />

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Sanchez&display=swap" rel="stylesheet" />

	<style>
		:root {
			--brand-yellow: #f6c700;
			--brand-orange: #e2572d;
			--brand-black: #1e1b16;
			--brand-ink: #0b0b0b;
			--brand-cream: #f2eee6;
			--brand-surface: #2f2f2f;
		}

		* { margin: 0; padding: 0; box-sizing: border-box; }

		body {
			font-family: 'Sanchez', serif;
			background: var(--brand-ink);
			color: var(--brand-cream);
			min-height: 100vh;
			display: flex;
			justify-content: center;
			padding: 2rem 1rem;
		}

		.bio-container {
			width: 100%;
			max-width: 480px;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
		}

		.bio-avatar {
			width: 96px;
			height: 96px;
			border-radius: 50%;
			border: 3px solid var(--brand-yellow);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 2.5rem;
			background: var(--brand-surface);
		}

		.bio-name {
			font-family: 'Poppins', sans-serif;
			font-size: 1.5rem;
			font-weight: 700;
			color: var(--brand-yellow);
			text-align: center;
		}

		.bio-tagline {
			font-size: 0.95rem;
			text-align: center;
			color: var(--brand-cream);
			line-height: 1.5;
			max-width: 340px;
		}

		.bio-intro {
			font-size: 0.92rem;
			text-align: center;
			color: var(--brand-cream);
			line-height: 1.65;
			max-width: 390px;
			opacity: 0.92;
		}

		.bio-links {
			width: 100%;
			display: flex;
			flex-direction: column;
			gap: 0.75rem;
		}

		.bio-link {
			display: block;
			width: 100%;
			padding: 1rem 1.25rem;
			text-align: center;
			text-decoration: none;
			font-family: 'Poppins', sans-serif;
			font-weight: 600;
			font-size: 1rem;
			color: var(--brand-black);
			background: var(--brand-yellow);
			border: 3px solid var(--brand-black);
			filter: drop-shadow(4px 4px 0 var(--brand-orange));
			transition: all 0.2s ease;
		}

		.bio-link:hover {
			filter: drop-shadow(2px 2px 0 var(--brand-orange));
			transform: translate(2px, 2px);
		}

		.bio-link.accent {
			background: var(--brand-orange);
			color: var(--brand-cream);
			filter: drop-shadow(4px 4px 0 var(--brand-yellow));
		}

		.bio-link.accent:hover {
			filter: drop-shadow(2px 2px 0 var(--brand-yellow));
			transform: translate(2px, 2px);
		}

		.bio-socials {
			display: flex;
			gap: 1.25rem;
			margin-top: 0.5rem;
		}

		.bio-socials a {
			color: var(--brand-cream);
			transition: color 0.2s ease;
		}

		.bio-socials a:hover {
			color: var(--brand-yellow);
		}

		.bio-socials svg {
			width: 28px;
			height: 28px;
		}

		.bio-footer {
			font-size: 0.8rem;
			color: var(--brand-cream);
			opacity: 0.6;
			margin-top: 1rem;
		}

		*,
		*::before,
		*::after {
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
			user-select: none;
		}

	</style>
</head>
<body>
	<script>
		(() => {
			const blockEvent = (event) => event.preventDefault();
			document.addEventListener("copy", blockEvent);
			document.addEventListener("cut", blockEvent);
			document.addEventListener("contextmenu", blockEvent);
			document.addEventListener("selectstart", blockEvent);
			document.addEventListener("dragstart", blockEvent);
			document.addEventListener("keydown", (event) => {
				if (!(event.ctrlKey || event.metaKey)) return;
				const key = event.key.toLowerCase();
				if (["a", "c", "u", "x"].includes(key)) event.preventDefault();
			});
		})();
	</script>
	<div class="bio-container">
		<div class="bio-avatar">
			<span>&#x1F469;&#x200D;&#x1F4BB;</span>
		</div>

		<h1 class="bio-name">DIANE / GOCHARBON</h1>

		<p class="bio-tagline">
			Française, 36 ans, je construis des produits et des contenus pour aider les gens à passer de l'idée au concret.
		</p>

		<p class="bio-intro">
			{SITE.name}, c'est mon terrain de jeu sérieux : un média utile, des parcours, des outils et des plans d'action pour les francophones qui veulent construire quelque chose de solide. Avec un peu d'humour, un peu de nerfs, et le moins de bullshit possible.
		</p>

		<div class="bio-links">
			<a href={getSiteUrl(ROUTES.parcours)} class="bio-link accent">Commencer par les parcours</a>
			<a href={getSiteUrl(ROUTES.quiz)} class="bio-link">Faire le quiz business</a>
			<a href={getSiteUrl(ROUTES.home)} class="bio-link">Accueil</a>
			<a href={getSiteUrl(ROUTES.blog)} class="bio-link">Blog</a>
			<a href={getSiteUrl(ROUTES.outils)} class="bio-link">Voir les outils</a>
			<a href={getSiteUrl(getBlogTagRoute("productivite"))} class="bio-link">Productivité & exécution</a>
			<a href={getSiteUrl("/#guide-outils-francais-gratuits")} class="bio-link">Recevoir le guide des outils français</a>
		</div>

		<div class="bio-socials">
			<!-- Twitter/X -->
			<a href="https://x.com/gocharbon" aria-label="Twitter / X" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
			</a>
			<!-- LinkedIn -->
			<a href="https://linkedin.com/company/gocharbon" aria-label="LinkedIn" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</a>
			<!-- Instagram -->
			<a href="https://instagram.com/gocharbon" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
			</a>
			<!-- YouTube -->
			<a href="https://youtube.com/@gocharbon" aria-label="YouTube" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
			</a>
		</div>

		<p class="bio-footer">&copy; 2026 {SITE.name}</p>
	</div>
</body>
</html>
