---
import Layout from "../../layouts/Default.astro";
import { learningPaths, learningPathById } from "../../data/parcoursData";
import { getParcoursIdFromSlug, getParcoursSlug } from "../../data/parcoursSlugs";
import PathProgressTracker from "../../components/vue/PathProgressTracker.vue";

export function getStaticPaths() {
  return learningPaths.flatMap((path) => {
    const frenchSlug = getParcoursSlug(path.id);
    if (frenchSlug === path.id) {
      return [{ params: { id: frenchSlug } }];
    }

    return [{ params: { id: frenchSlug } }, { params: { id: path.id } }];
  });
}

const { id } = Astro.params;
const pathData = id ? learningPathById[getParcoursIdFromSlug(id)] : null;

if (!pathData) {
  return Astro.redirect('/parcours');
}
---

<Layout
  title={`Parcours ${pathData.profileTitle} | GOCHARBON`}
  description={`Parcours ${pathData.profileTitle}: fondations, specialisation et execution terrain.`}
  pageTitle={`Parcours ${pathData.profileTitle}`}
>
  <main class="min-h-screen bg-yellow-soft dark:bg-black py-12 md:py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="path-header">
          <p class="path-tag">{pathData.category}</p>
          <h1>{pathData.profileTitle}</h1>
          <p class="path-outcome">{pathData.outcome}</p>
          <div class="path-header-meta">
            <span>Niveau: {pathData.level}</span>
            <span>Duree: {pathData.estimatedDuration}</span>
            <a href={`/biz/profils/${pathData.profileSlug}`}>Voir la fiche profil</a>
          </div>
        </div>

        <PathProgressTracker client:load pathData={pathData} />

        <div class="path-actions">
          <a href="/quiz-avance" class="path-btn">Refaire le quiz avance</a>
          <a href="/parcours" class="path-btn secondary">Voir tous les parcours</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1280px;
  }

  .path-header {
    background: var(--brand-cream);
    border: 3px solid var(--brand-black);
    box-shadow: 6px 6px 0 var(--brand-black);
    padding: 1.25rem;
    margin-bottom: 1.2rem;
  }

  .path-tag {
    display: inline-block;
    border: 2px solid var(--brand-black);
    font-family: "Sanchez", serif;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    padding: 0.15rem 0.4rem;
    margin: 0;
  }

  .path-header h1 {
    margin: 0.5rem 0;
    font-size: 2rem;
  }

  .path-outcome {
    margin: 0.35rem 0 0.8rem;
    line-height: 1.5;
  }

  .path-header-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    font-size: 0.95rem;
  }

  .path-header-meta a {
    font-weight: 700;
    color: var(--brand-black);
  }

  .path-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .path-btn {
    display: inline-block;
    text-decoration: none;
    border: 3px solid var(--brand-black);
    box-shadow: 4px 4px 0 var(--brand-black);
    padding: 0.75rem 1rem;
    font-family: "Sanchez", serif;
    font-weight: 700;
    background: var(--brand-yellow);
    color: var(--brand-black);
  }

  .path-btn.secondary {
    background: var(--brand-cream);
  }

  :global(.dark) .path-header {
    background: var(--brand-ink);
    border-color: var(--brand-cream);
    box-shadow: 6px 6px 0 var(--brand-cream);
    color: var(--brand-cream);
  }

  :global(.dark) .path-tag {
    border-color: var(--brand-cream);
  }

  :global(.dark) .path-header-meta a {
    color: var(--brand-yellow);
  }
</style>
