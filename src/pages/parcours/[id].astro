<script is:inline>
  (() => {
    const SECTION_ORDER = {
      plain: ["#1f2937", "#6b7280", "#9ca3af"],
      offers: ["#92400e", "#b45309", "#d97706"],
      plan: ["#9a3412", "#b45309", "#d97706"],
      tracking: ["#075985", "#0369a1", "#0284c7"],
      risks: ["#9f1239", "#be123c", "#e11d48"],
      deliverables: ["#14532d", "#166534", "#15803d"],
    };
    const PLAIN_TAGS = ["POUR QUI", "OU TROUVER DES CLIENTS", "TON PLUS"];

    const normalizeLabel = (value) =>
      value
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase();

    const compactLabel = (value) =>
      normalizeLabel(value)
        .replace(/[^a-z0-9]+/g, " ")
        .replace(/\s+/g, " ")
        .trim();

    const createLabelNode = (text) => {
      const strong = document.createElement("strong");
      strong.textContent = text.toLocaleUpperCase("fr-FR");
      return strong;
    };

    const createValueNode = (text, useEmphasis) => {
      const node = document.createElement(useEmphasis ? "em" : "span");
      node.textContent = text.trim();
      return node;
    };

    const applyTag = (listItem, sectionType, index) => {
      const palette = SECTION_ORDER[sectionType];
      if (!palette) {
        return;
      }

      const tag = document.createElement("strong");
      tag.className = "path-inline-tag";
      tag.style.color = palette[index % palette.length];
      const rank = index + 1;

      if (sectionType === "offers") tag.textContent = `OFFRE ${rank}`;
      else if (sectionType === "plan") tag.textContent = `JOUR ${rank}`;
      else if (sectionType === "tracking") tag.textContent = `KPI ${rank}`;
      else if (sectionType === "risks") tag.textContent = `RISQUE ${rank}`;
      else if (sectionType === "deliverables") tag.textContent = `LIVRABLE ${rank}`;
      else if (sectionType === "plain") tag.textContent = PLAIN_TAGS[index] ?? `POINT ${rank}`;
      else tag.textContent = `POINT ${rank}`;

      listItem.prepend(tag, document.createTextNode(" "));
    };

    const enhanceListItem = (listItem, sectionType, index) => {
      if (listItem.children.length > 0 || listItem.dataset.enhanced === "1") {
        return;
      }

      const raw = (listItem.textContent || "").trim();
      const dayMatch = raw.match(/^((?:jour|jours)\s*[0-9]+(?:\s*-\s*[0-9]+)?)\s*:\s*(.+)$/i);
      const genericMatch = raw.match(/^([^:]{2,42})\s*:\s*(.+)$/);

      listItem.textContent = "";

      if (dayMatch) {
        const [, , value] = dayMatch;
        const body = createValueNode(value, false);
        listItem.append(body);
        applyTag(listItem, sectionType, index);
        listItem.dataset.enhanced = "1";
        return;
      }

      if (genericMatch) {
        const [, label, value] = genericMatch;
        if (sectionType === "plain") {
          const body = createValueNode(value, true);
          listItem.append(body);
          applyTag(listItem, sectionType, index);
          listItem.dataset.enhanced = "1";
          return;
        }

        const prefix = createLabelNode(`${label}:`);
        const body = createValueNode(
          value,
          sectionType === "deliverables"
        );
        listItem.append(prefix, document.createTextNode(" "), body);
        applyTag(listItem, sectionType, index);
        listItem.dataset.enhanced = "1";
        return;
      }

      if (sectionType === "offers") {
        const text = createValueNode(raw, false);
        listItem.append(text);
      } else if (sectionType === "plan") {
        const text = createValueNode(raw, false);
        listItem.append(text);
      } else {
        const text = createValueNode(raw, false);
        listItem.append(text);
      }

      applyTag(listItem, sectionType, index);
      listItem.dataset.enhanced = "1";
    };

    const enhanceEditorial = () => {
      const headings = document.querySelectorAll(".path-editorial h2");
      headings.forEach((heading) => {
        const label = compactLabel(heading.textContent || "");
        if (label.includes("objectif")) {
          heading.classList.add("path-objective-heading");
        }
        if (label.includes("7 jours") || (label.includes("plan") && label.includes("jour"))) {
          heading.classList.add("path-plan-heading");
        }

        let sectionType = "";
        if (label.includes("en clair")) {
          heading.classList.add("path-plain-heading");
          sectionType = "plain";
        } else if (label.includes("idees d offres")) {
          heading.classList.add("path-offers-heading");
          sectionType = "offers";
        } else if (label.includes("ton plan simple") || label.includes("7 jours")) {
          sectionType = "plan";
        } else if (label.includes("chiffres utiles") || label.includes("a suivre")) {
          heading.classList.add("path-tracking-heading");
          sectionType = "tracking";
        } else if (label.includes("pieges")) {
          heading.classList.add("path-risks-heading");
          sectionType = "risks";
        } else if (label.includes("a la fin")) {
          heading.classList.add("path-deliverables-heading");
          sectionType = "deliverables";
        }

        if (!sectionType) {
          return;
        }

        let body = heading.nextElementSibling;
        if (!body?.classList.contains("path-editorial-section-body")) {
          const container = document.createElement("div");
          container.classList.add("path-editorial-section-body", `path-section-${sectionType}`);
          let cursor = heading.nextElementSibling;

          while (cursor && cursor.tagName !== "H2") {
            const next = cursor.nextElementSibling;
            container.appendChild(cursor);
            cursor = next;
          }

          if (container.childElementCount === 0) {
            return;
          }

          heading.insertAdjacentElement("afterend", container);
          body = container;
        } else {
          body.classList.add(`path-section-${sectionType}`);
        }

        body.querySelectorAll(":scope > ul > li, :scope > ol > li").forEach((item, index) => {
          enhanceListItem(item, sectionType, index);
        });
      });
    };

    enhanceEditorial();
    document.addEventListener("astro:page-load", enhanceEditorial);
  })();
</script>
