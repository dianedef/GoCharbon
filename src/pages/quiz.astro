---
import Layout from "../layouts/Default.astro";
---

<Layout
  title="Quiz Business - Rapide ou Avancé | GOCHARBON"
  description="Choisis ton format: quiz rapide 2 minutes pour une direction immédiate, ou quiz avancé pour un diagnostic business plus précis."
  pageTitle="Quiz Business"
>
  <main class="min-h-screen bg-yellow-soft dark:bg-black py-12 md:py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10 md:mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-4 poppins text-black dark:text-yellow-soft">
            Choisis Ton Format de Quiz
          </h1>
          <p class="text-lg md:text-xl text-gray-700 dark:text-gray-300">
            Rapide pour démarrer vite, avancé pour une recommandation plus fiable
          </p>
        </div>

        <div class="quiz-chooser-grid">
          <a href="/quiz-rapide" data-astro-prefetch class="quiz-choice-card">
            <p class="choice-badge">2 minutes</p>
            <h2>Quiz Rapide</h2>
            <p>Direction immédiate, top 2 profils, actions concrètes pour commencer aujourd'hui.</p>
            <span class="choice-cta">Lancer le quiz rapide →</span>
          </a>

          <a href="/quiz-avance" data-astro-prefetch class="quiz-choice-card">
            <p class="choice-badge">~15 minutes</p>
            <h2>Quiz Avancé</h2>
            <p>Diagnostic approfondi basé sur tes compétences, contraintes, objectifs et style de travail.</p>
            <span class="choice-cta">Lancer le quiz avancé →</span>
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1280px;
  }

  .quiz-chooser-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .quiz-choice-card {
    display: block;
    text-decoration: none;
    background: var(--brand-cream);
    border: 3px solid var(--brand-black);
    box-shadow: 6px 6px 0 var(--brand-black);
    padding: 1.5rem;
    color: var(--brand-black);
    transition: all 0.2s ease-in-out;
  }

  .quiz-choice-card:hover {
    transform: translate(2px, 2px);
    box-shadow: 4px 4px 0 var(--brand-black);
    background: var(--brand-yellow);
  }

  .choice-badge {
    display: inline-block;
    font-family: "Sanchez", serif;
    font-weight: 700;
    border: 2px solid var(--brand-black);
    padding: 0.2rem 0.6rem;
    margin: 0 0 0.75rem;
  }

  .quiz-choice-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.5rem;
  }

  .quiz-choice-card p {
    margin: 0 0 0.8rem;
    line-height: 1.5;
  }

  .choice-cta {
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .quiz-chooser-grid {
      grid-template-columns: 1fr;
    }
  }

  :global(.dark) .quiz-choice-card {
    background: var(--brand-ink);
    border-color: var(--brand-cream);
    box-shadow: 6px 6px 0 var(--brand-cream);
    color: var(--brand-cream);
  }

  :global(.dark) .quiz-choice-card:hover {
    background: var(--brand-charcoal);
    box-shadow: 4px 4px 0 var(--brand-cream);
  }

  :global(.dark) .choice-badge {
    border-color: var(--brand-cream);
    color: var(--brand-cream);
  }
</style>
