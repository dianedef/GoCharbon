---
import Layout from "../layouts/Default.astro";
import Quiz from "../components/vue/Quiz.vue";
import { quizData } from "../data/quizData.js";
import { getParcoursSlug } from "../data/parcoursSlugs";
import { getCollection } from "astro:content";

const profileToEntryId = {
  ecommerce: "biz/profils/ecommerce",
  saas: "biz/profils/saas",
  content: "biz/profils/content-creator",
  service: "biz/profils/freelance",
  formation: "biz/profils/formation",
  livecommerce: "biz/profils/livecommerce",
} as const;
const profileToLearningPathId = {
  ecommerce: "ecommerce",
  saas: "saas",
  content: "content-creator",
  service: "freelance",
  formation: "formation",
  livecommerce: "livecommerce",
} as const;

const requiredIds = new Set(Object.values(profileToEntryId));
const bizEntries = await getCollection("posts", ({ id }) => requiredIds.has(id));

const quizBizProfiles = Object.fromEntries(
  Object.entries(profileToEntryId).map(([profileKey, entryId]) => {
    const entry = bizEntries.find((item) => item.id === entryId);
    return [
      profileKey,
      entry
        ? {
            title: entry.data.title,
            description: entry.data.description,
            slug: `/${entry.id}`,
            tags: entry.data.tags,
            learningPathId: profileToLearningPathId[profileKey as keyof typeof profileToLearningPathId],
            learningPathUrl: `/parcours/${getParcoursSlug(profileToLearningPathId[profileKey as keyof typeof profileToLearningPathId])}`,
          }
        : null,
    ];
  })
);

const prefillRaw = Astro.url.searchParams.get("prefill");
let prefillAnswers: Array<{ questionId: number; optionIndex: number }> = [];

if (prefillRaw) {
  try {
    const parsed = JSON.parse(prefillRaw);
    if (Array.isArray(parsed)) {
      prefillAnswers = parsed.filter(
        (item) =>
          item &&
          Number.isInteger(item.questionId) &&
          Number.isInteger(item.optionIndex) &&
          item.optionIndex >= 0
      );
    }
  } catch {
    prefillAnswers = [];
  }
}
---

<Layout
  title="Quiz Business Avancé - Diagnostic 15 min | GOCHARBON"
  description="Quiz business avancé: diagnostic complet pour identifier le modèle le plus adapté à ton profil, tes talents et tes contraintes."
  pageTitle="Quiz Business Avancé"
>
  <main class="min-h-screen bg-yellow-soft dark:bg-black py-12 md:py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-8 md:mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-4 poppins text-black dark:text-yellow-soft">
            Quiz Business Avancé
          </h1>
          <p class="text-lg md:text-xl text-gray-700 dark:text-gray-300">
            Diagnostic approfondi pour une recommandation plus précise
          </p>
        </div>

        <Quiz client:load bizProfiles={quizBizProfiles} data={quizData} mode="advanced" prefillAnswers={prefillAnswers} />
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1280px;
  }
</style>
