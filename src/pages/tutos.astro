---
import { getCollection } from "astro:content";
import Layout from "../layouts/Default.astro";
import PostGrid from "../components/components/PostGrid.astro";
import Button from "../components/components/Button.astro";
import ParcoursCallToAction from "../components/ParcoursCallToAction.astro";
import { applyContentScope } from "../utils/content-section";
import { filterBuildVisiblePosts } from "../utils/build-posts";

const tutosPosts = applyContentScope(filterBuildVisiblePosts(await getCollection("posts")), "tutos")
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 30);
const pillarTags = [
	{ label: "Tutoriels", href: "/tag/tutoriels" },
	{ label: "Marketing", href: "/tag/marketing" },
	{ label: "Tech", href: "/tag/tech" },
	{ label: "Productivité", href: "/tag/productivite" },
];
---

<Layout
	title="Tutoriels Business & Tech pour Entrepreneurs"
	description="Tutoriels GOCHARBON : guides actionnables, pas à pas, pour exécuter plus vite sur le web. Marketing, SEO, outils et productivité."
	pageTitle="Tutos GOCHARBON"
>
	<main class="px-2 md:px-6 py-6 max-w-7xl mx-auto">
		<h1 class="poppins text-3xl md:text-4xl font-bold mb-6 text-black dark:text-white">Tutoriels GOCHARBON</h1>
		<ParcoursCallToAction variant="compact" />
		<section class="mb-8 mt-6 p-4 md:p-6 border-3 border-black dark:border-yellow-soft bg-white-soft dark:bg-black">
			<h2 class="poppins text-2xl md:text-3xl font-bold mb-3 text-black dark:text-white">Pages piliers</h2>
			<p class="poppins text-lg mb-4 text-black dark:text-white">
				Accès direct aux thèmes principaux, sans filtre interactif.
			</p>
			<div class="flex flex-wrap gap-3">
				{pillarTags.map((tag) => (
					<Button href={tag.href} color="var(--brand-copper)">
						{tag.label}
					</Button>
				))}
			</div>
		</section>
		<PostGrid posts={tutosPosts} />
	</main>
</Layout>

<style>
	.page-background {
		transition: background-color 0.3s ease;
	}
</style>
