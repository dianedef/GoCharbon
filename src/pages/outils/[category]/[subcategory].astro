---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Default.astro";
import PostGrid from "../../../components/components/PostGrid.astro";
import Button from "../../../components/components/Button.astro";
import { filterBuildVisiblePosts } from "../../../utils/build-posts";
import {
	buildToolTaxonomyIndex,
	getToolCategoryHref,
	getToolSubcategoryHref,
	getToolTaxonomy,
} from "../../../utils/tool-taxonomy";

const allToolPosts = filterBuildVisiblePosts(await getCollection("posts"))
	.filter((post) => !!getToolTaxonomy(post))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const toolIndex = buildToolTaxonomyIndex(allToolPosts);
const subcategoryEntries = toolIndex.flatMap((category) =>
	category.subcategories.map((subcategory) => ({
		category,
		subcategory,
	}))
);

export async function getStaticPaths() {
	const allToolPosts = filterBuildVisiblePosts(await getCollection("posts"))
		.filter((post) => !!getToolTaxonomy(post))
		.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
	const toolIndex = buildToolTaxonomyIndex(allToolPosts);
	const subcategoryEntries = toolIndex.flatMap((category) =>
		category.subcategories.map((subcategory) => ({
			category,
			subcategory,
		}))
	);

	return subcategoryEntries.map(({ category, subcategory }) => ({
		params: {
			category: category.slug,
			subcategory: subcategory.slug,
		},
		props: {
			category,
			subcategory,
		},
	}));
}

const { category, subcategory } = Astro.props;
const posts = allToolPosts.filter((post) => {
	const taxonomy = getToolTaxonomy(post);
	return taxonomy?.category === category.slug && taxonomy.subcategory === subcategory.slug;
});
const metaRobots = posts.length >= 3 ? "index, follow" : "noindex, follow";
---

<Layout
	title={`${subcategory.label} | ${category.label} | GoCharbon`}
	description={`Sélection d'outils ${subcategory.label.toLowerCase()} dans la catégorie ${category.label.toLowerCase()}. Fiches et avis pour entrepreneurs.`}
	pageTitle={subcategory.label}
	metaRobots={metaRobots}
>
	<main class="px-2 md:px-6 py-6 max-w-7xl mx-auto">
		<section class="mb-8 p-4 md:p-6 border-3 border-black dark:border-yellow-soft bg-white-soft dark:bg-black">
			<p class="poppins text-sm md:text-base mb-3 text-black dark:text-white">
				<a href="/outils" class="underline">Outils</a>
				{" / "}
				<a href={getToolCategoryHref(category.slug)} class="underline">{category.label}</a>
				{" / "}
				{subcategory.label}
			</p>
			<h1 class="poppins text-3xl md:text-5xl font-bold mb-3 text-black dark:text-white">
				{subcategory.label}
			</h1>
			<p class="poppins text-lg mb-4 text-black dark:text-white">
				Sous-catégorie utile pour l'utilisateur. Elle reste indexable seulement quand le volume la justifie.
			</p>
			<div class="flex flex-wrap gap-3">
				<Button href={getToolCategoryHref(category.slug)} color="var(--brand-copper)">
					Retour à {category.label}
				</Button>
				{category.subcategories.map((entry) => (
					<Button
						href={getToolSubcategoryHref(category.slug, entry.slug)}
						color={entry.slug === subcategory.slug ? "var(--brand-orange)" : "var(--brand-yellow)"}
					>
						{entry.label} ({entry.count})
					</Button>
				))}
			</div>
		</section>

		<PostGrid posts={posts} />
	</main>
</Layout>
