---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Default.astro";
import PostGrid from "../../components/components/PostGrid.astro";
import Button from "../../components/components/Button.astro";
import { filterBuildVisiblePosts } from "../../utils/build-posts";
import {
	buildToolTaxonomyIndex,
	getToolSubcategoryHref,
	getToolTaxonomy,
} from "../../utils/tool-taxonomy";

const allToolPosts = filterBuildVisiblePosts(await getCollection("posts"))
	.filter((post) => !!getToolTaxonomy(post))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const toolIndex = buildToolTaxonomyIndex(allToolPosts);

export async function getStaticPaths() {
	const allToolPosts = filterBuildVisiblePosts(await getCollection("posts"))
		.filter((post) => !!getToolTaxonomy(post))
		.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
	const toolIndex = buildToolTaxonomyIndex(allToolPosts);

	return toolIndex.map((category) => ({
		params: { category: category.slug },
		props: { category },
	}));
}

const { category } = Astro.props;
const posts = allToolPosts.filter((post) => getToolTaxonomy(post)?.category === category.slug);
---

<Layout
	title={`${category.label} | Outils | GoCharbon`}
	description={`Selection d'outils ${category.label.toLowerCase()} sur GoCharbon.`}
	pageTitle={category.label}
	metaRobots="index, follow"
>
	<main class="px-2 md:px-6 py-6 max-w-7xl mx-auto">
		<section class="mb-8 p-4 md:p-6 border-3 border-black dark:border-yellow-soft bg-white-soft dark:bg-black">
			<p class="poppins text-sm md:text-base mb-3 text-black dark:text-white">
				<a href="/outils" class="underline">Outils</a> / {category.label}
			</p>
			<h1 class="poppins text-3xl md:text-5xl font-bold mb-3 text-black dark:text-white">
				Outils {category.label.toLowerCase()}
			</h1>
			<p class="poppins text-lg mb-4 text-black dark:text-white">
				Une page categorie indexable, avec les outils ranges par taxonomie canonique plutot que par tags flous.
			</p>
			<div class="flex flex-wrap gap-3">
				<Button href="/outils" color="var(--brand-copper)">Toutes les categories</Button>
				{category.subcategories.map((subcategory) => (
					<Button
						href={getToolSubcategoryHref(category.slug, subcategory.slug)}
						color="var(--brand-yellow)"
					>
						{subcategory.label} ({subcategory.count})
					</Button>
				))}
			</div>
		</section>

		<PostGrid posts={posts} />
	</main>
</Layout>
