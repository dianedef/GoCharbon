---
import type { CollectionEntry } from "astro:content";
import Layout from "./Default.astro";
import Content from "@components/components/PostContent.astro";
import SideBar from "@components/components/PostSideBar.astro";
import RelatedPosts from "@components/components/RelatedPosts.astro";
import ParcoursCallToAction from "@components/ParcoursCallToAction.astro";
import GamificationBar from "@components/vue/GamificationBar.vue";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { learningPaths } from "../data/parcoursData";
import { getParcoursRoute } from "../config/routes";
import type { ToolQualification } from "../utils/tool-qualification";

interface Props {
	author: string;
	pubDate: Date;
	headings: Array<Object>;
	description: string;
	title: string;
	id: string;
	imgUrl: ImageMetadata;
	tags?: string[];
	section?: "blog" | "outils" | "tutos" | "parcours";
	toolCategoryPrimary?: string;
	toolSubcategoryPrimary?: string;
	toolFacets?: string[];
	toolQualification?: ToolQualification;
}

const {
	author,
	pubDate,
	headings,
	description,
	title,
	id,
	imgUrl,
	tags,
	section,
	toolCategoryPrimary,
	toolSubcategoryPrimary,
	toolFacets,
	toolQualification,
} =
	Astro.props;
const slug = Astro.params.slug as string;
const category = tags?.[0]?.toLowerCase();

const matchingPaths = learningPaths.filter(path =>
	path.modules.some(mod =>
		mod.steps.some(step => step.href === `/${slug}` || step.href === `/${id}`)
	)
);

// SoftwareApplication JSON-LD pour les fiches outils
const isToolPage = section === "outils" && toolCategoryPrimary;
const toolSchema = isToolPage
	? {
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			name: title,
			description: description,
			applicationCategory: toolCategoryPrimary,
			url: Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname,
			author: {
				"@type": "Organization",
				name: "GOCHARBON",
				url: "https://gocharbon.com",
			},
		}
	: null;
---

<Layout title={title} description={description} ogImage="/v1/generate/og/default.png" article={{ author, pubDate, tags }}>
	{toolSchema && (
		<script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />
	)}
	<div class="p-6 dark:bg-black" transition:name={`post-${id}`}>
		<main class="lg:grid lg:grid-cols-3 flex justify-center gap-4">
			<SideBar headings={headings as any[]} />
			<div class="col-span-2 max-w-full">
				<h1
					class="text-xl md:text-2xl font-bold mb-2 md:my-4 poppins dark:text-yellow-soft"
					transition:name={`title-${id}`}
				>
					{title}
				</h1>
				<div
					class="rounded-lg border-3 border-black dark:border-white h-24 md:h-56"
				>
					<Image
						src={imgUrl}
						alt={description}
						width={800}
						height={400}
						class="rounded h-full w-full object-cover"
						transition:name={`image-${id}`}
					/>
				</div>
				<Content
					postId={id}
					{pubDate}
					{author}
					{section}
					toolQualification={toolQualification}
					toolCategoryPrimary={toolCategoryPrimary}
					toolSubcategoryPrimary={toolSubcategoryPrimary}
					toolFacets={toolFacets}
				>
					<slot />
				</Content>
			</div>
		</main>
		<section class="mt-12">
			<RelatedPosts
				currentSlug={id}
				currentTags={tags || []}
				currentSection={section}
				currentToolCategoryPrimary={toolCategoryPrimary}
				currentToolSubcategoryPrimary={toolSubcategoryPrimary}
				currentToolFacets={toolFacets || []}
				count={4}
			/>
		</section>
		{matchingPaths.length > 0 && (
			<section class="mt-8 p-6 bg-yellow-soft dark:bg-purple-darker border-3 border-black dark:border-purple-bright">
				<p class="text-lg font-bold poppins text-black dark:text-white mb-3">
					Cet article fait partie de {matchingPaths.length} parcours :
				</p>
				<ul class="flex flex-wrap gap-3">
					{matchingPaths.map(path => (
						<li>
							<a
								href={getParcoursRoute(path.id)}
								class="inline-block px-4 py-2 bg-white-soft dark:bg-black border-2 border-black dark:border-purple-bright font-bold poppins text-black dark:text-white hover:bg-yellow-primary dark:hover:bg-purple-dark transition-colors"
							>
								{path.profileTitle}
							</a>
						</li>
					))}
				</ul>
			</section>
		)}
		<div class="mt-8">
			<ParcoursCallToAction variant="compact" />
		</div>
	</div>
	<GamificationBar client:load slug={slug} category={category} />
</Layout>

<style>
	::view-transition-old(*),
	::view-transition-new(*) {
		animation-duration: 0.3s;
		animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
	}
</style>
