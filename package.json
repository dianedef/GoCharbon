{
  "name": "brutal",
  "version": "1.2.0",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@8.6.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=8.6.0 <9"
  },
  "pnpm": {
    "overrides": {
      "@eslint/config-array>minimatch": "3.1.4",
      "@eslint/eslintrc>minimatch": "3.1.4",
      "@rollup/pluginutils>picomatch": "4.0.4",
      "@typescript-eslint/typescript-estree>minimatch": "9.0.7",
      "@parcel/watcher>picomatch": "4.0.4",
      "anymatch>picomatch": "2.3.2",
      "astro>picomatch": "4.0.4",
      "astro>svgo": "4.0.1",
      "eslint>minimatch": "3.1.4",
      "eslint-plugin-jsx-a11y>minimatch": "3.1.4",
      "flat-cache>flatted": "3.4.2",
      "fdir>picomatch": "4.0.4",
      "h3>defu": "6.1.5",
      "micromatch>picomatch": "2.3.2",
      "tinyglobby>picomatch": "4.0.4",
      "unconfig>defu": "6.1.5",
      "unstorage>h3": "1.15.6",
      "vite>rollup": "4.59.0"
    }
  },
  "author": {
    "name": "Elian Van Cutsem",
    "email": "hello@elian.codes",
    "url": "https://www.elian.codes/"
  },
  "homepage": "https://brutal.elian.codes",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 3014",
    "start": "astro dev --host 0.0.0.0 --port 3014",
    "build": "PARCOURS_ONLY_BUILD=1 astro build",
    "build:full": "astro build",
    "build:no-outils": "EXCLUDE_OUTILS_FROM_BUILD=1 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "audit:parcours": "node scripts/audit_parcours_content.mjs",
    "audit:outils": "python3 scripts/audit_outils_content.py",
    "audit:outils:qualification": "python3 scripts/audit_outils_qualification.py",
    "audit:outils:doublons": "python3 scripts/audit_outils_duplicate_mirrors.py",
    "prune:outils:doublons": "python3 scripts/prune_outils_same_parent_duplicates.py",
    "prune:outils:doublons:similaires": "python3 scripts/prune_outils_high_similarity_duplicates.py",
    "qa:outils:qualification": "python3 scripts/qa_outils_qualification.py",
    "sync:outils:qualification": "python3 scripts/sync_outils_qualification_duplicates.py",
    "backlog:outils:qualification": "python3 scripts/prioritize_outils_qualification.py --limit 300 --format markdown"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@diane-winflowz/gamification": "github:dianedef/gamification",
    "astro": "^6.1.9",
    "astro-font": "^1.1.0",
    "lucide-astro": "^0.556.0",
    "satori": "^0.19.1",
    "satori-html": "^0.3.2"
  },
  "devDependencies": {
    "@astrojs/vue": "6.0.1",
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/uil": "^1.2.3",
    "@resvg/resvg-js": "^2.6.2",
    "@typescript-eslint/parser": "^8.59.1",
    "@unocss/astro": "^66.6.8",
    "@unocss/preset-attributify": "^66.6.8",
    "@unocss/preset-icons": "^66.6.8",
    "@unocss/preset-uno": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "unocss": "^66.6.8",
    "vue": "3.5.33"
  }
}
